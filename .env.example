# Default environment variables for Omni-LLM-Proxy
# Copy this to .env and customize for your setup

# Which LLM provider to use by default
# Options: chatgpt, claude, gemini
DEFAULT_PROVIDER=chatgpt

# API server port
PORT=5000

# Run browser in headless mode (true for production, false for debugging)
HEADLESS=true

# Timeout for waiting for LLM response (milliseconds)
RESPONSE_TIMEOUT=60000
